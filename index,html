<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sirius: A Ascensão do Desbravador</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #050b18;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
        }

        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at bottom, #1a2a6c, #b21f1f, #050b18);
            transition: background 2s;
        }

        /* O Desbravador */
        #desbravador {
            position: absolute;
            bottom: 50px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            transition: bottom 1.5s ease-in-out, transform 0.5s;
            text-align: center;
        }

        .lenco {
            width: 20px;
            height: 20px;
            background-color: #FFD700; /* Amarelo */
            margin: 0 auto;
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
        }

        .corpo {
            width: 30px;
            height: 40px;
            background-color: #333;
            margin: -5px auto 0;
            border-radius: 5px;
        }

        /* UI */
        #ui-panel {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(0, 0, 0, 0.7);
            padding: 20px;
            border-radius: 10px;
            border: 1px solid #FFD700;
            max-width: 300px;
        }

        #btn-subir {
            display: none;
            background-color: #FFD700;
            color: #000;
            border: none;
            padding: 10px 20px;
            font-weight: bold;
            cursor: pointer;
            border-radius: 5px;
            margin-top: 10px;
        }

        #btn-subir:hover { background-color: #fff; }

        /* Estrelas */
        .estrela-alvo {
            position: absolute;
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, #fff, transparent);
            border-radius: 50%;
            box-shadow: 0 0 20px #fff;
            display: none;
            justify-content: center;
            align-items: center;
            font-size: 12px;
            font-weight: bold;
            color: gold;
        }

        /* Tela Final */
        #tela-final {
            display: none;
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            z-index: 100;
        }

        #img-final {
            width: 80%;
            max-width: 600px;
            border: 3px solid #FFD700;
            border-radius: 15px;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div id="ui-panel">
        <h2 id="nome-estrela">Início</h2>
        <p id="missao-texto">Clique em Iniciar para decolar!</p>
        <div id="quiz-area"></div>
        <button id="btn-subir" onclick="proximaFase()">SUBIR ↑</button>
        <button id="btn-start" onclick="iniciarJogo()">INICIAR DECOLAGEM</button>
    </div>

    <div id="desbravador">
        <div class="lenco"></div>
        <div class="corpo"></div>
        <small>SIRIUS</small>
    </div>

    <div id="estrela-visual" class="estrela-alvo"></div>
</div>

<div id="tela-final">
    <h1 style="color: #FFD700;">PARABÉNS!</h1>
    <p>Você completou tudo e foi abençoado(a)!</p>
    <img id="img-final" src="https://i.imgur.com/8N6y7Vn.jpg" alt="Benção Final">
    <br>
    <button onclick="location.reload()" style="padding: 10px;">RECOMEÇAR</button>
</div>

<script>
    const fases = [
        { nome: "Órion", missao: "Qual é a cor oficial do lenço de Desbravador?", resposta: "amarelo", pos: "20%" },
        { nome: "Andrômeda", missao: "Quantos pontos tem a estrela da saúde?", resposta: "8", pos: "35%" },
        { nome: "Pegasus", missao: "O que significa Sirius no nosso clube?", resposta: "estrela", pos: "55%" },
        { nome: "Cruzeiro do Sul", missao: "Qual livro da bíblia diz: 'Os que ensinam brilharão como estrelas'?", resposta: "daniel", pos: "70%" },
        { nome: "SIRIUS", missao: "Você está pronto para brilhar? (Digite: sim)", resposta: "sim", pos: "85%" }
    ];

    let faseAtual = -1;

    function iniciarJogo() {
        document.getElementById('btn-start').style.display = 'none';
        proximaFase();
    }

    function proximaFase() {
        faseAtual++;
        
        if (faseAtual >= fases.length) {
            finalizarJogo();
            return;
        }

        const dados = fases[faseAtual];
        
        // Atualiza UI
        document.getElementById('nome-estrela').innerText = "Estrela: " + dados.nome;
        document.getElementById('missao-texto').innerText = "MISSÃO: " + dados.missao;
        document.getElementById('btn-subir').style.display = 'none';
        
        // Input de resposta
        const quizArea = document.getElementById('quiz-area');
        quizArea.innerHTML = `<input type="text" id="input-resposta" placeholder="Sua resposta...">
                              <button onclick="verificarResposta()">Confirmar</button>`;
        
        // Move o desbravador visualmente
        const player = document.getElementById('desbravador');
        player.style.bottom = dados.pos;

        // Mostra a estrela no cenário
        const estrela = document.getElementById('estrela-visual');
        estrela.style.display = 'flex';
        estrela.style.bottom = dados.pos;
        estrela.style.right = (Math.random() * 70 + 10) + "%";
        estrela.innerText = dados.nome;
    }

    function verificarResposta() {
        const resp = document.getElementById('input-resposta').value.toLowerCase();
        if (resp.includes(fases[faseAtual].resposta)) {
            alert("Missão Cumprida!");
            document.getElementById('quiz-area').innerHTML = "<b style='color:lime'>Fase Concluída!</b>";
            document.getElementById('btn-subir').style.display = 'block';
        } else {
            alert("Resposta errada! Tente novamente.");
        }
    }

    function finalizarJogo() {
        document.getElementById('game-container').style.display = 'none';
        document.getElementById('tela-final').style.display = 'flex';
    }
</script>

</body>
</html>
